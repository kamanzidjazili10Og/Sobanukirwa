  { arabic: "لَا إِلَٰهَ إِلَّا اللَّهُ", transliteration: "La ilaha illallah", translation: "Nta mana iri isobok uretse Allah", count: 10, category: "general" },
  { arabic: "أَسْتَغْفِرُ اللَّهَ", transliteration: "Astaghfirullah", translation: "Nsaba imbabazi kwa Allah", count: 10, category: "general" },
  { arabic: "سُبْحَانَ اللَّهِ وَبِحَمْدِهِ", transliteration: "Subhanallahi wa bihamdihi", translation: "Ibyubahiro n'ishimwe ni ibya Allah", count: 100, category: "morning" },
  { arabic: "لَا إِلَٰهَ إِلَّا اللَّهُ وَحْدَهُ لَا شَرِيكَ لَهُ", transliteration: "La ilaha illallahu wahdahu la sharika lah", translation: "Nta mana iri isobok uretse Allah wenyine, ntawo umufatanyije", count: 10, category: "morning" }
];

function initFallbackData() {
  artistsData.length = 0;
  booksData.length = 0;
  videosData.length = 0;
  surahs.length = 0;
  adhkarList.length = 0;
  fallbackArtists.forEach(a => artistsData.push({...a, tracks: a.tracks.map(t => ({...t}))}));
  fallbackBooks.forEach(b => booksData.push({...b}));
  fallbackVideos.forEach(v => videosData.push({...v}));
  fallbackSurahs.forEach(s => surahs.push({...s}));
  fallbackAdhkar.forEach(a => adhkarList.push({...a}));
  if (typeof generateIds === 'function') generateIds();
  if (typeof renderQuran === 'function') renderQuran();
  if (typeof renderArtists === 'function') renderArtists();
  if (typeof renderBooks === 'function') renderBooks();
  if (typeof renderVideos === 'function') renderVideos();
  if (typeof renderCarousel === 'function') renderCarousel();
  if (typeof updateStats === 'function') updateStats();
  if (typeof renderVideoFilters === 'function') renderVideoFilters();
}
