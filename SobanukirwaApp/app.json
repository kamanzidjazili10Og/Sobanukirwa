{
  "expo": {
    "name": "Sobanukirwa - Islamic App",
    "slug": "sobanukirwa",
    "owner": "kamanzidjazili",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#F8FAFC",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sobanukirwa.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Sobanukirwa needs your location for prayer times and Qibla direction"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F8FAFC"
      },
      "package": "com.sobanukirwa.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png",
      "title": "Sobanukirwa - Islamic App",
      "description": "Sobanukirwa Islamic - Learn the truth, knowledge, and beauty of Islam"
    },
    "plugins": [
      "expo-av",
      "expo-notifications",
      "expo-asset",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Sobanukirwa needs your location for prayer times and Qibla direction"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7c74e9e3-e361-4429-af1e-77d2417c24ca"
      }
    }
  }
}
