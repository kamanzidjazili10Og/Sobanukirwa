{
  "expo": {
    "name": "Sobanukirwa",
    "slug": "sobanukirwa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0b1a2a",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sobanukirwa.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Sobanukirwa needs your location for prayer times and Qibla direction"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0b1a2a"
      },
      "package": "com.sobanukirwa.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-av",
      "expo-notifications",
      "expo-asset",
      "expo-font"
    ]
  }
}
